# Must include the /api suffix; the client prepends /v1/... to every path.
VITE_API_BASE_URL=https://your-backend-host/api

# Error reporting (optional). Leave empty and Sentry never loads — every call is a
# no-op and the bundle does not carry it.
VITE_SENTRY_DSN=
# Defaults to the Vite mode. Set to `production` on the deployed client.
VITE_SENTRY_ENV=
# A commit SHA or version, so a report says which bundle it came from.
VITE_RELEASE=
